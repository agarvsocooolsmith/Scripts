		local barAbsSize = bar.AbsoluteSize.X
		local alpha = math.clamp((inputX - barAbsPos) / barAbsSize, 0, 1)
		return min + (max - min) * alpha
	end

	local dragging = false

	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setValue(getValueFromInput(input.Position.X))
		end
	end)

	game:GetService("UserInputService").InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setValue(getValueFromInput(input.Position.X))
		end
	end)

	game:GetService("UserInputService").InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	if _G.AgarWareSave and configKey and _G.AgarWareSave[configKey] ~= nil then
		setValue(_G.AgarWareSave[configKey])
	else
		setValue(default)
	end

	return {
		setValue = setValue,
		getValue = function() return currentValue end,
	}
end
end)
