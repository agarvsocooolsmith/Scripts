pcall(function()
local script=_AGARWARE["221"];
local TWEEN_INFO = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

_G.AgarWareSlider = {}
_G.AgarWareSlider.new = function(config)
	local frame = config.frame
	local configKey = config.configKey
	local min = config.min or 0
	local max = config.max or 100
	local default = config.default or min
	local decimals = config.decimals or 0
	local snap = config.snap or false
	local sliderText = config.sliderText or "{{current}}/{{max}}"
	local callback = config.callback or function() end

	local slider = frame:WaitForChild("slider")
	local bar = slider:WaitForChild("bar")
	local fill = bar:WaitForChild("fill")
	local dot = bar:WaitForChild("dot")
	local valueLabel = frame:WaitForChild("value")

	local currentValue = default

	local function round(n)
		local factor = 10 ^ decimals
		return math.round(n * factor) / factor
	end

	local function formatText(val)
		local text = sliderText
		local fmt = "%." .. decimals .. "f"
		text = text:gsub("{{min}}", string.format(fmt, min))
		text = text:gsub("{{max}}", string.format(fmt, max))
		text = text:gsub("{{current}}", string.format(fmt, val))
		return text
	end

	local function getAlpha(val)
		return (val - min) / (max - min)
	end

	local function updateVisuals(val)
		local alpha = getAlpha(val)
		local ts = game:GetService("TweenService")
		ts:Create(dot, TWEEN_INFO, { Position = UDim2.new(alpha, 0, 0.5, 0) }):Play()
		ts:Create(fill, TWEEN_INFO, { Size = UDim2.new(alpha, 0, 1, 0) }):Play()
		valueLabel.Text = formatText(val)
	end

	local function setValue(val)
		val = math.clamp(val, min, max)
		if snap then
			local factor = 10 ^ decimals
			val = math.round(val * factor) / factor
		end
		currentValue = val
		if _G.AgarWareSave and configKey then
			_G.AgarWareSave[configKey] = val
		end
		updateVisuals(val)
		callback(val)
	end

	local function getValueFromInput(inputX)
		local barAbsPos = bar.AbsolutePosition.X
		local barAbsSize = bar.AbsoluteSize.X
		local alpha = math.clamp((inputX - barAbsPos) / barAbsSize, 0, 1)
		return min + (max - min) * alpha
	end

	local dragging = false

	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setValue(getValueFromInput(input.Position.X))
		end
	end)

	game:GetService("UserInputService").InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setValue(getValueFromInput(input.Position.X))
		end
	end)

	game:GetService("UserInputService").InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	if _G.AgarWareSave and configKey and _G.AgarWareSave[configKey] ~= nil then
		setValue(_G.AgarWareSave[configKey])
	else
		setValue(default)
	end

	return {
		setValue = setValue,
		getValue = function() return currentValue end,
	}
end
end)
end;
task.spawn(C_221)
end;
