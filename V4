local function C_222()
pcall(function()
local script=_AGARWARE["222"];
local screenGui = script:FindFirstAncestorWhichIsA("ScreenGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local TWEEN_INFO = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local warnUIs = {
	warn1 = screenGui.warn1,
	warn2 = screenGui.warn2,
	warn3 = screenGui.warn3,
}

local isMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled

for _, warnUI in pairs(warnUIs) do
	warnUI.GroupTransparency = 1
	warnUI.UIStroke.Transparency = 1
	warnUI.Visible = false
	if isMobile then
		local padding = warnUI.UIPadding
		padding.PaddingTop = UDim.new(0, padding.PaddingTop.Offset + 10)
		padding.PaddingBottom = UDim.new(0, padding.PaddingBottom.Offset - 2)
	end
end

local function getTargetPosition(warnUI, button)
	local scale = screenGui.UIScale and screenGui.UIScale.Scale or 1
	local buttonCenter = button.AbsolutePosition.X + button.AbsoluteSize.X / 2
	local posX = (buttonCenter - screenGui.AbsolutePosition.X - warnUI.AbsoluteSize.X / 2) / scale
	local posY = (button.AbsolutePosition.Y - screenGui.AbsolutePosition.Y - warnUI.AbsoluteSize.Y - 5) / scale
	return UDim2.fromOffset(posX, posY)
end

for warnName, warnUI in pairs(warnUIs) do
	local hoverCount = 0
	for _, button in pairs(screenGui:GetDescendants()) do
		if button:IsA("TextButton") and button.Name == warnName then
			button.MouseEnter:Connect(function()
				hoverCount += 1
				warnUI.Position = getTargetPosition(warnUI, button)
				warnUI.Visible = true
				TweenService:Create(warnUI, TWEEN_INFO, {GroupTransparency = 0}):Play()
				TweenService:Create(warnUI.UIStroke, TWEEN_INFO, {Transparency = 0}):Play()
			end)
			button.MouseLeave:Connect(function()
				hoverCount -= 1
				if hoverCount <= 0 then
					hoverCount = 0
					TweenService:Create(warnUI, TWEEN_INFO, {GroupTransparency = 1}):Play()
					TweenService:Create(warnUI.UIStroke, TWEEN_INFO, {Transparency = 1}):Play()
					task.delay(0.15, function()
						if hoverCount == 0 then
							warnUI.Visible = false
						end
					end)
				end
			end)
		end
	end
end
end)
end;
task.spawn(C_222)
end;

return _AGARWARE["1"], require;
