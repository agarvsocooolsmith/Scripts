		local scale = screenGui.UIScale.Scale
		local screenHeight = screenGui.AbsoluteSize.Y
		local dropdownHeight = dropdownUI.Size.Y.Offset
		local posX = (frame.AbsolutePosition.X - screenGui.AbsolutePosition.X) / scale
		local posYBelow = (frame.AbsolutePosition.Y + frame.AbsoluteSize.Y - screenGui.AbsolutePosition.Y + 7) / scale
		local posYAbove = (frame.AbsolutePosition.Y - screenGui.AbsolutePosition.Y - dropdownHeight - 7) / scale
		local goesOffScreen = (frame.AbsolutePosition.Y + frame.AbsoluteSize.Y + dropdownHeight) > (screenGui.AbsolutePosition.Y + screenHeight)
		return UDim2.fromOffset(posX, goesOffScreen and posYAbove or posYBelow)
	end

