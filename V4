local function C_5()
pcall(function()
local script=_AGARWARE["5"];
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local frame = script.Parent
local screenGui = frame.Parent
frame.Active = true
if not RunService:IsStudio() then
	screenGui.Parent = game:GetService("CoreGui")
end

local dragging = false
local dragStart
local startPos
local DRAG_TWEEN = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function getScale()
	local uiScale = screenGui:FindFirstChildOfClass("UIScale")
	return uiScale and uiScale.Scale or 1
end

local function update(input)
	local delta = input.Position - dragStart
	local scale = getScale()
	local position = UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + (delta.X / scale),
		startPos.Y.Scale,
		startPos.Y.Offset + (delta.Y / scale)
	)
	TweenService:Create(frame, DRAG_TWEEN, {Position = position}):Play()
end

frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragging then
		update(input)
	end
end)
end)
end;
task.spawn(C_5)
end;
