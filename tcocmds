local function getPos(obj)
	return tostring(math.round(obj.CFrame.X)) .. "," .. tostring(math.round(obj.CFrame.Y)) .. "," .. tostring(math.round(obj.CFrame.Z))
end

local positionMap = {}
local addedConn = nil
