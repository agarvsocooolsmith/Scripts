	else
		enabledCmds[name:lower()] = nil
		_G.ConfigData["agarwarecmd_" .. name:lower()] = nil
	end
	pcall(function()
		writefile("awcmdsave.json", game:GetService("HttpService"):JSONEncode(_G.ConfigData))
	end)
	updateStatusLabel()
end
local function executeCmd(input)
	if input == "" then return end
	local args = {}
	for word in input:gmatch("%S+") do
		table.insert(args, word)
	end
	local cmdName = table.remove(args, 1):lower()
	if commands[cmdName] then
		pcall(commands[cmdName], args)
	else
		_G.agarwarecmdnotify("Unknown command: " .. cmdName)
	end
end
