			if target and target:IsA("BasePart") and target.Parent and target.Parent.Parent == workspace:FindFirstChild("Bricks") then
				highlight.Adornee = target
			else
				highlight.Adornee = nil
			end
		end)
	end)

	clickTool.Unequipped:Connect(function()
		highlight.Adornee = nil
		if renderConn then renderConn:Disconnect() renderConn = nil end
	end)

	clickTool.Activated:Connect(function()
		local char = LocalPlayer.Character
		if not char then return end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
		if mouse.Hit then
			local currentRotation = hrp.CFrame - hrp.CFrame.Position
			hrp.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0)) * currentRotation
		end
	end)

	clickTool.AncestryChanged:Connect(function()
		if not clickTool.Parent then
			highlight:Destroy()
			if renderConn then renderConn:Disconnect() renderConn = nil end
		end
	end)
end

