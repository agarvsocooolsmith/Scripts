	for _, obj in ipairs(bricks:GetDescendants()) do
		if nameRestore[obj.Name] then pcall(nameRestore[obj.Name], obj) end
	end
end

local function updateTransparency(bricks)
	positionMap = {}
	for _, obj in ipairs(bricks:GetDescendants()) do
		if obj.Name == "Brick" and obj:IsA("BasePart") then
			local pos = getPos(obj)
			if not positionMap[pos] then
				positionMap[pos] = obj
				obj.Transparency = obj.Material == Enum.Material.Glass and 0.5 or 0
			else
				obj.Transparency = 1
			end
		end
	end
end

local function restoreTransparency(bricks)
	for _, obj in ipairs(bricks:GetDescendants()) do
		if obj.Name == "Brick" and obj:IsA("BasePart") then
			obj.Transparency = obj.Material == Enum.Material.Glass and 0.5 or 0
		end
	end
