	local Players = game:GetService("Players")
	local CoreGui = game:GetService("CoreGui")
	local player = Players.LocalPlayer
	local playerGui = player:WaitForChild("PlayerGui")
	
	local myGui = script.Parent
	local characters = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=[]{}|;:',.<>?/~ "
	local trackedObjects = {}
	
	-- Check if in Studio - if so, skip CoreGui
	local canAccessCoreGui = not RunService:IsStudio()
	
	local function getRandomChar()
		return string.sub(characters, math.random(1, #characters), math.random(1, #characters))
	end
	
	local function randomizeText(length)
		local result = ""
		for i = 1, length do
			result = result .. getRandomChar()
		end
		return result
	end
	
	local function isInMyGui(object)
		local parent = object
		while parent do
			if parent == myGui then return true end
			parent = parent.Parent
		end
		return false
	end
	
	local function trackTextObject(obj)
		if not isInMyGui(obj) and not trackedObjects[obj] then
			trackedObjects[obj] = {
				originalText = obj.Text,
				originalLength = #obj.Text
			}
		end
	end
	
	-- Scan function
	local function scanForText(container)
		for _, obj in pairs(container:GetDescendants()) do
			if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
				trackTextObject(obj)
			end
		end
	end
	
	-- Initial scan - PlayerGui
	scanForText(playerGui)
	
	-- Initial scan - Workspace
	scanForText(workspace)
	
	-- Initial scan - CoreGui (only if not in Studio)
	if canAccessCoreGui then
		pcall(function()
			scanForText(CoreGui)
		end)
	end
	
	-- Listen for new objects in PlayerGui
	playerGui.DescendantAdded:Connect(function(obj)
		if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
			trackTextObject(obj)
		end
	end)
	
	-- Listen for new objects in Workspace
	workspace.DescendantAdded:Connect(function(obj)
		if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
			trackTextObject(obj)
		end
	end)
	
	-- Listen for new objects in CoreGui (only if not in Studio)
	if canAccessCoreGui then
		pcall(function()
			CoreGui.DescendantAdded:Connect(function(obj)
				if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
					trackTextObject(obj)
				end
			end)
		end)
	end
	
	-- Randomize loop
	while true do
		wait(0.1)
	
		for obj, data in pairs(trackedObjects) do
			if obj and obj.Parent then
				pcall(function()
					obj.Text = randomizeText(data.originalLength)
				end)
			else
				trackedObjects[obj] = nil
			end
		end
	end
end;
